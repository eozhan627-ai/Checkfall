{
  "expo": {
    "name": "Checkfall",
    "slug": "Checkfall",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "checkfall",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/images/app-icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.checkfall",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.anonymous.checkfall",
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundColor": "#ffffff"
      }
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ec981dac-3054-4a76-afb6-9110e13d2ca7"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ec981dac-3054-4a76-afb6-9110e13d2ca7"
    },
    "owner": "eneskazim.oezhan"
  }
}